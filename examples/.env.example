# Copy this file to .env and fill in your credentials
# Get these from the DNSE portal: https://openapi.dnse.com.vn
DNSE_API_KEY=your-api-key-here
DNSE_API_SECRET=your-api-secret-here

# Sub-account number — required for account/order/deal examples
# Find yours by running: python quickstart.py
DNSE_ACCOUNT_NO=your-account-number-here

# Optional: override the REST API base URL (default: https://openapi.dnse.com.vn)
# DNSE_BASE_URL=https://openapi.dnse.com.vn
